# =====================================================
# 23:47 Backend — Variables de entorno
# Copia como `.env` y rellena los valores reales.
# NUNCA subas `.env` a Git.
# =====================================================

# ── App
NODE_ENV=development
PORT=4000

# ── Base de datos
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5433/YOUR_DB_NAME

# ── Redis
REDIS_URL=redis://localhost:6379

# ── Auth / JWT
# Usa strings largos y aleatorios (mín. 32 caracteres)
JWT_SECRET=YOUR_STRONG_JWT_SECRET
JWT_REFRESH_SECRET=YOUR_STRONG_JWT_REFRESH_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# ── Spotify OAuth
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET
SPOTIFY_REDIRECT_URI=http://localhost:4000/api/spotify/callback

# ── Frontend
# Desarrollo: FRONTEND_URL=http://localhost:5173
# Producción (Railway): FRONTEND_URL=https://23-47.app,http://localhost:5173
# (comma-separated para múltiples orígenes)
FRONTEND_URL=http://localhost:5173

# ── Cloudflare R2 (persistent image storage)
# Obtén las credenciales en: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=23-47-rooms
# URL pública del bucket (actívala en R2 → Settings → Public access)
R2_PUBLIC_URL=https://pub-XXXXXX.r2.dev

# ── Producción (Railway / Neon / Upstash)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# REDIS_URL=rediss://USER:PASSWORD@HOST:PORT   (rediss:// = TLS)
# SPOTIFY_REDIRECT_URI=https://tu-backend.railway.app/api/spotify/callback
# NODE_ENV=production
