// =====================================================
// 23:47 — Prisma schema
// PostgreSQL · Neon · Driver adapter GA (Prisma 5.4+)
// =====================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS ====================
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String    @unique
  displayName  String    @map("display_name")
  passwordHash String    @map("password_hash")
  avatarUrl    String?   @map("avatar_url")
  bio          String?
  theme        String    @default("madrugada-2003")
  currentMood  String?   @map("current_mood")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Spotify
  spotifyId           String?   @unique @map("spotify_id")
  spotifyAccessToken  String?   @map("spotify_access_token")
  spotifyRefreshToken String?   @map("spotify_refresh_token")
  spotifyTokenExpires DateTime? @map("spotify_token_expires")

  // Relations
  status             UserStatus?
  digitalRoom        DigitalRoom?
  culturalProfile    UserCulturalProfile?
  ambientMemoryEvents AmbientMemoryEvent[]
  friendships        Friend[]              @relation("UserFriends")
  friendOf           Friend[]              @relation("FriendOfUser")
  nostalgiaSessions  NostalgiaSession[]
  aiRecommendations  AiRecommendation[]
  refreshTokens      RefreshToken[]
  roomPresences      RoomPresence[]
  conversations      ConversationParticipant[]
  sentMessages       Message[]

  @@map("users")
}

// ==================== USER STATUS ====================
model UserStatus {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  status       String   @default("online") // online | away | dnd | invisible | offline
  customStatus String?  @map("custom_status")
  spotifyTrack  String? @map("spotify_track")
  spotifyArtist String? @map("spotify_artist")
  spotifyCover  String? @map("spotify_cover")
  spotifyUrl    String? @map("spotify_url")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_status")
}

// ==================== FRIENDS ====================
model Friend {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  status    String   @default("accepted") // pending | accepted | blocked
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOfUser", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@map("friends")
}

// ==================== ROOMS — Phase 2 ====================
model Room {
  id             String   @id @default(uuid())
  slug           String   @unique
  title          String
  atmosphereType String   @map("atmosphere_type") // rain | crt | warm | neon | calm | wind
  createdAt      DateTime @default(now()) @map("created_at")

  presence RoomPresence[]

  @@map("rooms")
}

model RoomPresence {
  id         String   @id @default(uuid())
  roomId     String   @map("room_id")
  userId     String   @map("user_id")
  joinedAt   DateTime @default(now()) @map("joined_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("room_presence")
}

// ==================== MESSENGER — Phase 3 ====================
model Conversation {
  id             String   @id @default(uuid())
  ephemeral      Boolean  @default(false)
  atmosphereType String?  @map("atmosphere_type")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")
  userId         String @map("user_id")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  content        String
  messageType    String    @default("text") @map("message_type") // text | nudge | spotify
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ==================== DIGITAL ROOMS — Phase 7 ====================
model DigitalRoom {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  theme          String   @default("madrugada-2003")
  background     String?
  musicTheme     String?  @map("music_theme")
  ambient        String?  // rain | crt | warm | neon | calm | wind
  nostalgiaData  Json?    @map("nostalgia_data") // full EnhancedRoom profile
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items RoomItem[]

  @@map("digital_rooms")
}

model RoomItem {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  type      String   // poster | console | lamp | crt | plant | vinyl | photo
  positionX Int      @default(0) @map("position_x")
  positionY Int      @default(0) @map("position_y")
  rotation  Int      @default(0)
  scale     Float    @default(1)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  room DigitalRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("room_items")
}

// ==================== AI / NOSTALGIA — Phase 4/6 ====================
model NostalgiaSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  era       String
  mood      String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("nostalgia_sessions")
}

model AiRecommendation {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  recommendation String
  type           String   // era | room | nostalgia | music
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("ai_recommendations")
}

// ==================== CULTURAL MEMORY ENGINE — Phase 6+ ====================
model UserCulturalProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  generation          String?                          // "millenial_spanish", "gen_z_spanish"
  region              String?                          // south_spain | madrid | catalonia | universal
  detectedEraRange    String?  @map("detected_era_range") // "2004-2008"
  nostalgiaPackId     String?  @map("nostalgia_pack_id")
  musicIdentity       Json?    @map("music_identity")
  culturalVector      Json?    @map("cultural_vector")  // scored dims from matching engine
  ambientPreferences  Json?    @map("ambient_preferences")
  lastReconstructedAt DateTime? @map("last_reconstructed_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_cultural_profiles")
}

// ==================== AMBIENT MEMORY EVENTS (Fase 8) ====================
model AmbientMemoryEvent {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  memoryId      String   @map("memory_id")        // cultural-memory.ts id
  memoryCategory String  @map("memory_category")  // tv | music | games | internet …
  hourOfDay     Int      @map("hour_of_day")       // 0-23
  dayOfWeek     Int      @map("day_of_week")       // 0=Sun … 6=Sat
  dismissed     Boolean  @default(false)           // did user dismiss immediately?
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, hourOfDay])
  @@index([userId, memoryCategory])
  @@map("ambient_memory_events")
}

// ==================== AUTH ====================
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
